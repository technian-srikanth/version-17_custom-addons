<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_webhook_config_form" model="ir.ui.view">
        <field name="name">webhook.config.form</field>
        <field name="model">webhook.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="url"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <!--                    <field name="model_id"/>-->
                        <field name="on_create"/>
                        <field name="on_update"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_webhook_config_tree" model="ir.ui.view">
        <field name="name">webhook.config.tree</field>
        <field name="model">webhook.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="url"/>
                <field name="active"/>
                <!--                <field name="model_id"/>-->
                <field name="on_create"/>
                <field name="on_update"/>
            </tree>
        </field>
    </record>

    <record id="action_webhook_config" model="ir.actions.act_window">
        <field name="name">webhook</field>
        <field name="res_model">webhook.config</field>
        <field name="view_mode">tree,form</field>
        <!--        <field name="view_id" ref="ts_webhook.view_webhook_config_tree"/>-->
    </record>
</odoo>