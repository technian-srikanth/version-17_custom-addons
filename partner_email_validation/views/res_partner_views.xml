<odoo>

    <record id="view_partner_form_email_validation"
            model="ir.ui.view">
        <field name="name">res.partner.form.email.validation</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Add Button in Header -->
            <xpath expr="//sheet" position="before">
                <header>
                    <button name="action_validate_email"
                            type="object"
                            string="Validate Email"
                            class="oe_highlight"/>
                </header>
            </xpath>
            <!-- Add Fields -->
            <xpath expr="//sheet" position="inside">
                <group string="Email Validation">
                    <field name="email_valid" readonly="1" widget="boolean_toggle"/>
                    <field name="batch"/>
                    <field name="validation_msg" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>